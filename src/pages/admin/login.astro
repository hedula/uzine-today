---
// SSR — public within Zero Trust boundary
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>登入 | 隅誌今時</title>
  </head>
  <body class="min-h-screen bg-stone-100 text-stone-900">
    <main class="mx-auto flex min-h-screen max-w-sm flex-col justify-center px-6">
      <h1 class="text-xl font-bold">管理員登入</h1>
      <form class="mt-6 space-y-4" method="post" action="/api/auth/login">
        <div>
          <label class="block text-sm font-medium" for="password">密碼</label>
          <input
            id="password"
            name="password"
            type="password"
            required
            class="mt-1 w-full rounded border border-stone-300 px-3 py-2"
          />
        </div>
        <button
          type="submit"
          class="w-full rounded bg-stone-900 px-4 py-2 text-white hover:bg-stone-800"
        >
          登入
        </button>
      </form>
    </main>
  </body>
</html>
