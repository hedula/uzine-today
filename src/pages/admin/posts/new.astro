<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>新增文章 | 隅誌今時</title>
  </head>
  <body class="min-h-screen bg-stone-100 text-stone-900">
    <main class="mx-auto max-w-5xl px-6 py-12">
      <div class="flex items-end justify-between gap-4">
        <div>
          <a href="/admin/posts" class="text-sm text-stone-500 underline">← 文章列表</a>
          <h1 class="mt-3 text-3xl font-bold">新增文章</h1>
          <p class="mt-2 text-stone-600">第一版支援建立草稿與直接發布，內容以 Editor.js JSON 寫入 D1。</p>
        </div>
      </div>

      <form id="post-form" class="mt-8 grid gap-8 lg:grid-cols-[320px_minmax(0,1fr)]">
        <aside class="space-y-5 rounded-2xl border border-stone-200 bg-white p-6">
          <div>
            <label class="block text-sm font-medium text-stone-700" for="title">標題</label>
            <input
              id="title"
              name="title"
              required
              class="mt-1 w-full rounded-lg border border-stone-300 px-3 py-2"
              placeholder="請輸入文章標題"
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-stone-700" for="slug">Slug</label>
            <input
              id="slug"
              name="slug"
              required
              pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
              class="mt-1 w-full rounded-lg border border-stone-300 px-3 py-2"
              placeholder="my-first-post"
            />
            <p class="mt-1 text-xs text-stone-500">只接受小寫英數與 `-`。</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-stone-700" for="summary">摘要</label>
            <textarea
              id="summary"
              name="summary"
              rows="4"
              class="mt-1 w-full rounded-lg border border-stone-300 px-3 py-2"
              placeholder="文章摘要"
            ></textarea>
          </div>

          <div>
            <label class="block text-sm font-medium text-stone-700" for="cover_image_url">封面圖片 URL</label>
            <input
              id="cover_image_url"
              name="cover_image_url"
              type="url"
              class="mt-1 w-full rounded-lg border border-stone-300 px-3 py-2"
              placeholder="https://..."
            />
          </div>

          <div>
            <label class="block text-sm font-medium text-stone-700" for="status">狀態</label>
            <select
              id="status"
              name="status"
              class="mt-1 w-full rounded-lg border border-stone-300 px-3 py-2"
            >
              <option value="draft">Draft</option>
              <option value="published">Published</option>
            </select>
          </div>

          <button
            id="submit-button"
            type="submit"
            class="w-full rounded-lg bg-stone-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-stone-800"
          >
            儲存文章
          </button>

          <p id="form-status" class="text-sm text-stone-500"></p>
        </aside>

        <section class="rounded-2xl border border-stone-200 bg-white p-6">
          <div class="mb-4 flex items-center justify-between gap-3">
            <div>
              <h2 class="text-lg font-semibold">文章內容</h2>
              <p class="text-sm text-stone-500">支援 paragraph、header、list、quote、delimiter。</p>
            </div>
          </div>
          <div id="editorjs" class="min-h-[520px] rounded-xl border border-stone-200 bg-stone-50 px-4 py-5"></div>
        </section>
      </form>
    </main>

    <script type="module">
      import EditorJS from 'https://esm.sh/@editorjs/editorjs';
      import Header from 'https://esm.sh/@editorjs/header';
      import List from 'https://esm.sh/@editorjs/list';
      import Quote from 'https://esm.sh/@editorjs/quote';
      import Delimiter from 'https://esm.sh/@editorjs/delimiter';

      const form = document.querySelector('#post-form');
      const titleInput = document.querySelector('#title');
      const slugInput = document.querySelector('#slug');
      const summaryInput = document.querySelector('#summary');
      const coverInput = document.querySelector('#cover_image_url');
      const statusInput = document.querySelector('#status');
      const submitButton = document.querySelector('#submit-button');
      const formStatus = document.querySelector('#form-status');

      const editor = new EditorJS({
        holder: 'editorjs',
        placeholder: '開始撰寫內容...',
        autofocus: true,
        data: {
          blocks: [
            {
              type: 'paragraph',
              data: {
                text: '',
              },
            },
          ],
        },
        tools: {
          header: Header,
          list: List,
          quote: Quote,
          delimiter: Delimiter,
        },
      });

      titleInput?.addEventListener('input', () => {
        if (slugInput.dataset.edited === '1') return;

        const nextSlug = titleInput.value
          .trim()
          .toLowerCase()
          .replace(/[^a-z0-9\\s-]/g, '')
          .replace(/\\s+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '');

        slugInput.value = nextSlug;
      });

      slugInput?.addEventListener('input', () => {
        slugInput.dataset.edited = '1';
      });

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        submitButton.disabled = true;
        formStatus.textContent = '儲存中...';

        try {
          const content = await editor.save();
          const response = await fetch('/api/posts', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              title: titleInput.value,
              slug: slugInput.value,
              summary: summaryInput.value,
              cover_image_url: coverInput.value,
              status: statusInput.value,
              content,
            }),
          });

          const data = await response.json();

          if (!response.ok) {
            throw new Error(data.error || 'Failed to save post');
          }

          formStatus.textContent = `已儲存：${data.title} (${data.status})`;
          window.location.href = '/admin/posts';
        } catch (error) {
          formStatus.textContent = error instanceof Error ? error.message : '儲存失敗';
        } finally {
          submitButton.disabled = false;
        }
      });
    </script>
  </body>
</html>
