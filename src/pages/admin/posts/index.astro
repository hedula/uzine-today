---
import { getDb, listAdminPosts } from '@/lib/db';

const db = getDb(Astro.locals);
const posts = await listAdminPosts(db);
---

<html lang="zh-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>文章列表 | 隅誌今時</title>
  </head>
  <body class="min-h-screen bg-stone-100 text-stone-900">
    <main class="mx-auto max-w-5xl px-6 py-12">
      <div class="flex items-end justify-between gap-4">
        <div>
          <a href="/admin" class="text-sm text-stone-500 underline">← 後台</a>
          <h1 class="mt-3 text-3xl font-bold">文章列表</h1>
          <p class="mt-2 text-stone-600">目前顯示最近更新的文章草稿與已發布內容。</p>
        </div>
        <a
          href="/admin/posts/new"
          class="rounded bg-stone-900 px-4 py-2 text-sm font-medium text-white hover:bg-stone-800"
        >
          新增文章
        </a>
      </div>

      <div class="mt-8 overflow-hidden rounded-2xl border border-stone-200 bg-white">
        {posts.length === 0 ? (
          <div class="px-6 py-10 text-sm text-stone-500">尚無文章，先建立第一篇草稿。</div>
        ) : (
          <table class="min-w-full divide-y divide-stone-200 text-sm">
            <thead class="bg-stone-50 text-left text-stone-500">
              <tr>
                <th class="px-6 py-3 font-medium">標題</th>
                <th class="px-6 py-3 font-medium">Slug</th>
                <th class="px-6 py-3 font-medium">狀態</th>
                <th class="px-6 py-3 font-medium">分類</th>
                <th class="px-6 py-3 font-medium">發布時間</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone-100">
              {posts.map((post) => (
                <tr>
                  <td class="px-6 py-4 font-medium text-stone-900">{post.title}</td>
                  <td class="px-6 py-4 text-stone-500">{post.slug}</td>
                  <td class="px-6 py-4">
                    <span class="rounded-full bg-stone-100 px-2.5 py-1 text-xs font-medium text-stone-700">
                      {post.status}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-stone-500">{post.category_name ?? '未分類'}</td>
                  <td class="px-6 py-4 text-stone-500">{post.published_at ?? '未發布'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </main>
  </body>
</html>
